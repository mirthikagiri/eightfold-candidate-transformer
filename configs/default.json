{
  "fields": [
    {
      "path": "candidate_name",
      "from": "full_name",
      "required": true
    },
    {
      "path": "primary_email",
      "from": "emails[0]",
      "normalize": "email"
    },
    {
      "path": "primary_phone",
      "from": "phones[0]",
      "normalize": "E164"
    },
    {
      "path": "location_city",
      "from": "location.city"
    },
    {
      "path": "skills",
      "from": "skills",
      "normalize": "canonical"
    }
  ],
  "include_provenance": true,
  "include_confidence": true,
  "include_quality": true,
  "include_audit": true,
  "include_conflicts": true,
  "include_normalization_report": true,
  "on_missing": "null"
}
